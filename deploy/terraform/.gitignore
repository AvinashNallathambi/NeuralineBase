# Terraform state files (contain secrets — never commit)
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.*
crash.log
crash.*.log

# SSH key generated by Terraform
*.pem

# Terraform internal directories
.terraform/
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
