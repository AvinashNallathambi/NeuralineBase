# ─────────────────────────────────────────────────────────────────────────────
# Neuraline EMR – Environment Variables
# HIPAA-compliant configuration template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=neuraline
DB_USERNAME=neuraline
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── HIPAA: PHI Encryption Key ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM.
# The app will refuse to start in production without this.
ENCRYPTION_KEY=

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# Must be at least 32 characters in production.
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_min_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI Services ──────────────────────────────────────────────────────────────
# Provider: ollama, openrouter, groq, or openai
AI_PROVIDER=openrouter

# Ollama (local, default)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenRouter (free dev tier — get key at https://openrouter.ai/keys)
# Set AI_PROVIDER=openrouter to use this instead of Ollama.
# OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Groq (alternative free dev — get key at https://console.groq.com/keys)
# GROQ_API_KEY=gsk_YOUR_KEY_HERE
# GROQ_MODEL=llama-3.3-70b-versatile

# Whisper (audio transcription)
WHISPER_SERVICE_URL=http://localhost:8001
CHROMA_URL=http://localhost:8000

# ── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_NODE=http://localhost:9200
