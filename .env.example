# ─────────────────────────────────────────────────────────────────────────────
# Neuraline EMR – Environment Variables
# HIPAA-compliant configuration template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=neuraline
DB_USERNAME=neuraline
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── HIPAA: PHI Encryption Key ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM.
# The app will refuse to start in production without this.
ENCRYPTION_KEY=

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# Must be at least 32 characters in production.
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_min_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AI Services ──────────────────────────────────────────────────────────────
# AssemblyAI is used for speech-to-text transcription on the AI Encounter page.
# Sign up at https://www.assemblyai.com and paste your API key here.
# The AssemblyAI free tier includes $50 in testing credits.
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Legacy Whisper service (kept for fallback / local-only deployments)
WHISPER_SERVICE_URL=http://localhost:8001

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
CHROMA_URL=http://localhost:8000

# ── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_NODE=http://localhost:9200

# ── Email (Notifications) ────────────────────────────────────────────────────
# If RESEND_API_KEY is set, uses Resend (https://resend.com) for transactional emails.
# Otherwise, emails are logged to the console (mock mode for development).
# Resend free tier: 3,000 emails/month. HIPAA BAA available on paid plans.
RESEND_API_KEY=
MAIL_FROM_EMAIL=notifications@neuraline.health
MAIL_FROM_NAME=Neuraline Health
